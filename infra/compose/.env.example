# Copiar a .env y rellenar con valores reales (ver runbook).
# DO NOT COMMIT .env

# ── Postgres ──
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
POSTGRES_DB=streaming_bot
TEMPORAL_DB=temporal
TEMPORAL_VISIBILITY_DB=temporal_visibility

# ── ClickHouse ──
CLICKHOUSE_USER=app
CLICKHOUSE_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING
CLICKHOUSE_DB=events

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# ── MinIO (S3 compatible) ──
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# ── Grafana ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# ── Cloudflare Tunnel (opcional) ──
TUNNEL_TOKEN=

# ── App (Mes 2: API FastAPI) ──
SB_DATABASE__URL=postgresql+asyncpg://app:CHANGE_ME@10.10.0.20:5432/streaming_bot
SB_PROXY__MODE=provider_api
SB_PROXY__API_ENDPOINT=https://api.smartproxy.com/v1/get?country=$${country}
SB_PROXY__API_AUTH_HEADER=Authorization
SB_PROXY__API_AUTH_VALUE=Bearer YOUR_TOKEN
SB_PROXY__API_RESPONSE_PATH=
SB_OBSERVABILITY__METRICS_ENABLED=true
SB_OBSERVABILITY__METRICS_PORT=9091

# ── Sentry (opcional) ──
SENTRY_DSN=
