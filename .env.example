# ==============================================================================
# streaming-bot - Configuración 12-factor
# ==============================================================================
# Copia este archivo a .env y completa los valores. NUNCA commits .env.
# ------------------------------------------------------------------------------

# Entorno: development | staging | production
SB_ENV=development

# ------------------------------------------------------------------------------
# Browser (Playwright)
# ------------------------------------------------------------------------------
SB_BROWSER__HEADLESS=true
SB_BROWSER__SLOW_MO_MS=0
SB_BROWSER__DEFAULT_TIMEOUT_MS=30000
SB_BROWSER__VIEWPORT_WIDTH=1366
SB_BROWSER__VIEWPORT_HEIGHT=768

# ------------------------------------------------------------------------------
# Orquestador
# ------------------------------------------------------------------------------
# Cuántas cuentas ejecutar en paralelo
SB_CONCURRENCY=10
# Reintentos por cuenta antes de marcarla como fallida
SB_MAX_RETRIES=3
# Backoff inicial en segundos (exponencial)
SB_RETRY_BACKOFF_SECONDS=2

# ------------------------------------------------------------------------------
# Storage (sesiones cifradas + cuentas)
# ------------------------------------------------------------------------------
SB_STORAGE__ACCOUNTS_PATH=./credentials/accounts.encrypted
SB_STORAGE__SESSIONS_DIR=./sessions
SB_STORAGE__ARTIFACTS_DIR=./artifacts
# Clave maestra Fernet (genera una nueva con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SB_STORAGE__MASTER_KEY=

# ------------------------------------------------------------------------------
# Proxies
# ------------------------------------------------------------------------------
# none | static_file | provider_api
SB_PROXY__MODE=none
SB_PROXY__FILE_PATH=./credentials/proxies.txt
SB_PROXY__HEALTHCHECK_URL=https://api.ipify.org

# ------------------------------------------------------------------------------
# Observabilidad
# ------------------------------------------------------------------------------
# json | console
SB_OBSERVABILITY__LOG_FORMAT=console
# debug | info | warning | error
SB_OBSERVABILITY__LOG_LEVEL=info
SB_OBSERVABILITY__METRICS_ENABLED=true
SB_OBSERVABILITY__METRICS_PORT=9090

# ------------------------------------------------------------------------------
# Target site (genérico - el caso de uso recibe la URL por CLI)
# ------------------------------------------------------------------------------
# Demo seguro para tests E2E (Playwright provee este sitio público)
SB_DEMO_URL=https://demo.playwright.dev/todomvc/
