# Public API endpoint exposed at build time.
# If empty or unreachable the client falls back to in-memory fixtures.
NEXT_PUBLIC_API_URL=

# Better Auth configuration
# Generate a strong random secret (>= 32 chars), e.g.: openssl rand -base64 32
AUTH_SECRET=change-me-please-change-me-change-me-change
BETTER_AUTH_URL=http://localhost:3000

# Postgres connection for the auth schema (shared cluster, dedicated schema)
# Leave empty in local/dev to fall back to the in-memory auth adapter.
DATABASE_URL=

# Maplibre style (free demo tiles by default)
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Locale defaults (ISO 639-1)
NEXT_PUBLIC_DEFAULT_LOCALE=es
